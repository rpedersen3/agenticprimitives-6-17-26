{
  "name": "@agenticprimitives/scripture-content-extension",
  "version": "1.0.0-alpha.6",
  "description": "Scripture vertical for the verifiable-content substrate: the Bible canon (OSIS book codes), a versioned versification model, the scripture.verse selector, and alias parsing (scripture:book.chapter.verse + tolerant forms) that normalizes many surface grammars to ONE scheme-independent canonical locus. Depends on verifiable-content; carries no rendering text and no specific translation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentictrustlabs/agenticprimitives.git",
    "directory": "packages/scripture-content-extension"
  },
  "homepage": "https://github.com/agentictrustlabs/agenticprimitives/tree/master/packages/scripture-content-extension",
  "bugs": { "url": "https://github.com/agentictrustlabs/agenticprimitives/issues" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["LICENSE", "dist", "spec.md", "README.md", "CLAUDE.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": { "access": "public" },
  "peerDependencies": {
    "@agenticprimitives/content-primitives": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "vitest": "^4.1.8"
  },
  "keywords": ["scripture", "bible", "osis", "verifiable-content", "agentic"]
}
