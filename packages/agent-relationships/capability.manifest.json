    { "term": "NAMESPACE_CONTAINS", "reason": "Naming hierarchy lives in agent-naming (parent-pointer) per ADR-0006. NOT a relationship type in our model.", "owningPackage": "@agenticprimitives/agent-naming", "allowInPaths": ["src/constants.ts", "CLAUDE.md", "AUDIT.md", "README.md", "test/taxonomy.test.ts"] }
