{
  "name": "@agenticprimitives/key-custody",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/203-key-custody.md",
  "summary": "Envelope encryption + signers + HMAC providers. local-AES/AWS-KMS/GCP-KMS backends behind one A2AKeyProvider interface. No session lifecycle (that's delegation's).",
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": [
    "@agenticprimitives/types",
    "@agenticprimitives/identity-auth"
  ],
  "allowedImports": [
    "@agenticprimitives/types",
    "@agenticprimitives/identity-auth",
    "viem",
    "@noble/curves",
    "@noble/hashes",
    "@aws-sdk/client-kms",
    "@google-cloud/kms"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/agent-account",
    "@agenticprimitives/delegation",
    "@agenticprimitives/tool-policy",
    "@agenticprimitives/mcp-runtime"
  ],
  "publicExports": [
    "A2AKeyProvider",
    "KmsAccountBackend",
    "KmsBackend",
    "BuildOpts",
    "buildKeyProvider",
    "buildSignerBackend",
    "buildToolExecutorBackend",
    "buildMacProvider",
    "getRelayOnlySigner",
    "createKmsAccount",
    "canonicalContextBytes",
    "LocalAesProvider",
    "LocalSecp256k1Signer",
    "AwsKmsProvider",
    "AwsKmsSigner",
    "GcpKmsProvider",
    "GcpKmsSigner",
    "Address",
    "Hex"
  ],
  "forbiddenTerms": [
    { "term": "Delegation", "reason": "Authority concept; key-custody only encrypts opaque bytes. Even if the bytes happen to be a serialized delegation, this package doesn't know that.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "Caveat", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "Enforcer", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "SessionManager", "reason": "Lifecycle owned by delegation; key-custody only provides primitives the SessionManager calls.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "SessionRow", "reason": "Row shape is delegation's vocabulary.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "SessionPackage", "reason": "Payload shape is delegation's vocabulary; key-custody encrypts opaque bytes.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "JTI", "reason": "Belongs in delegation/mcp-runtime.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "RiskTier", "reason": "Belongs in tool-policy.", "owningPackage": "@agenticprimitives/tool-policy" },
    { "term": "evaluatePolicy", "reason": "Belongs in tool-policy.", "owningPackage": "@agenticprimitives/tool-policy" },
    { "term": "withDelegation", "reason": "Belongs in mcp-runtime.", "owningPackage": "@agenticprimitives/mcp-runtime" },
    { "term": "@modelcontextprotocol", "reason": "MCP transport is not key-custody's concern.", "owningPackage": "@agenticprimitives/mcp-runtime" },
    { "term": "passkey", "reason": "Auth method; belongs in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth", "allowInPaths": ["spec.md", "README.md"] },
    { "term": "OAuth", "reason": "Auth method; belongs in identity-auth. Exception: GcpKmsSigner uses Google's OAuth 2.0 service-account JWT-bearer flow as an upstream client to Cloud KMS — this is not user-facing auth, it's how the signer authenticates to GCP.", "owningPackage": "@agenticprimitives/identity-auth", "allowInPaths": ["spec.md", "README.md", "src/providers/gcp.ts", "test/unit/gcp-signer.test.ts"] },
    { "term": "SIWE", "reason": "Auth method; belongs in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth", "allowInPaths": ["spec.md", "README.md"] }
  ],
  "ignoreForAgentContext": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "*.tsbuildinfo"
  ],
  "contextBudget": {
    "claudeMdMaxWords": 1200,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
