    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@agenticprimitives/types": "workspace:*",
    "@agenticprimitives/ontology": "workspace:*",
