{
  "name": "@agenticprimitives/agent-account",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/201-agent-account.md",
  "summary": "ERC-4337 smart-account substrate. Deterministic addressing, factory deployment, ERC-1271 signing, UserOp building. Account-agnostic of which signer signs.",
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": ["@agenticprimitives/types", "@agenticprimitives/identity-auth"],
  "allowedImports": [
    "@agenticprimitives/types",
    "@agenticprimitives/identity-auth",
    "@agenticprimitives/identity-auth/passkey",
    "viem"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/delegation",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/tool-policy",
    "@agenticprimitives/mcp-runtime"
  ],
  "publicExports": [
    "AgentAccountClient",
    "AgentAccountClientOpts",
    "AgentAccountSpec",
    "UserOperation",
    "Address",
    "Hex",
    "BundlerClient",
    "BundlerClientOpts",
    "PackedUserOperation",
    "packGasLimits",
    "unpackGasLimits",
    "agentAccountAbi",
    "agentAccountFactoryAbi",
    "approvedHashRegistryAbi",
    "entryPointAbi",
    "SIG_TYPE_WEBAUTHN",
    "encodeAssertion",
    "encodeWebAuthnSignature",
    "packSafeSignatures",
    "computeAdminPayloadHash",
    "ADMIN_VERB_PROPOSE",
    "ADMIN_VERB_EXECUTE",
    "ADMIN_VERB_CANCEL",
    "SafeSignatureSlot",
    "buildExecuteCallData",
    "buildExecuteBatchCallData",
    "ContractCall"
  ],
  "forbiddenTerms": [
    {
      "term": "Caveat",
      "reason": "Belongs in delegation. agent-account may reference the term in cross-cutting-capability docstrings (spec 207 quorum integration).",
      "owningPackage": "@agenticprimitives/delegation",
      "allowInPaths": ["src/quorum.ts", "spec.md", "README.md", "CLAUDE.md", "AUDIT.md"]
    },
    {
      "term": "Enforcer",
      "reason": "Belongs in delegation.",
      "owningPackage": "@agenticprimitives/delegation"
    },
    {
      "term": "SessionManager",
      "reason": "Belongs in delegation.",
      "owningPackage": "@agenticprimitives/delegation"
    },
    {
      "term": "DelegationToken",
      "reason": "Belongs in delegation.",
      "owningPackage": "@agenticprimitives/delegation"
    },
    {
      "term": "A2AKeyProvider",
      "reason": "Belongs in key-custody. agent-account consumes signers via identity-auth's Signer interface only.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "envelope encryption",
      "reason": "Belongs in key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "RiskTier",
      "reason": "Belongs in tool-policy.",
      "owningPackage": "@agenticprimitives/tool-policy"
    },
    {
      "term": "withDelegation",
      "reason": "Belongs in mcp-runtime.",
      "owningPackage": "@agenticprimitives/mcp-runtime"
    },
    {
      "term": "MCP",
      "reason": "Transport-specific; this package is transport-free.",
      "owningPackage": "@agenticprimitives/mcp-runtime",
      "allowInPaths": ["spec.md", "README.md"]
    },
    {
      "term": "passkey",
      "reason": "Auth method internals belong in identity-auth. The on-chain factory methods (createAccountWithPasskey / getAddressForPasskey) and the signature dispatch ABI are agent-account's contract surface; the WebAuthn signature encoder may reference identity-auth's subpath URL.",
      "owningPackage": "@agenticprimitives/identity-auth",
      "allowInPaths": [
        "spec.md",
        "README.md",
        "CLAUDE.md",
        "src/webauthn-signature.ts",
        "src/abis.ts",
        "src/client.ts",
        "test/unit/webauthn-signature.test.ts"
      ]
    },
    {
      "term": "OAuth",
      "reason": "Auth method internals belong in identity-auth.",
      "owningPackage": "@agenticprimitives/identity-auth",
      "allowInPaths": ["spec.md", "README.md"]
    }
  ],
  "ignoreForAgentContext": ["dist/**", "node_modules/**", "coverage/**", "*.tsbuildinfo"],
  "contextBudget": {
    "claudeMdMaxWords": 1100,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
