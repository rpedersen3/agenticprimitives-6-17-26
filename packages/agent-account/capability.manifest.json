{
  "name": "@agenticprimitives/agent-account",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/201-agent-account.md",
  "summary": "ERC-4337 smart-account substrate. Deterministic addressing, factory deployment, ERC-1271 signing, UserOp building. Account-agnostic of which signer signs.",
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": [
    "@agenticprimitives/types",
    "@agenticprimitives/identity-auth"
  ],
  "allowedImports": [
    "@agenticprimitives/types",
    "@agenticprimitives/identity-auth",
    "viem"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/delegation",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/tool-policy",
    "@agenticprimitives/mcp-runtime"
  ],
  "publicExports": [
    "AgentAccountClient",
    "AgentAccountClientOpts",
    "CreateAgentAccountParams",
    "UserOperation",
    "Address",
    "Hex"
  ],
  "forbiddenTerms": [
    { "term": "Caveat", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "Enforcer", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "SessionManager", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "DelegationToken", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "A2AKeyProvider", "reason": "Belongs in key-custody. agent-account consumes signers via identity-auth's Signer interface only.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "envelope encryption", "reason": "Belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "RiskTier", "reason": "Belongs in tool-policy.", "owningPackage": "@agenticprimitives/tool-policy" },
    { "term": "withDelegation", "reason": "Belongs in mcp-runtime.", "owningPackage": "@agenticprimitives/mcp-runtime" },
    { "term": "MCP", "reason": "Transport-specific; this package is transport-free.", "owningPackage": "@agenticprimitives/mcp-runtime", "allowInPaths": ["spec.md", "README.md"] },
    { "term": "passkey", "reason": "Auth method internals belong in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth", "allowInPaths": ["spec.md", "README.md", "CLAUDE.md"] },
    { "term": "OAuth", "reason": "Auth method internals belong in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth", "allowInPaths": ["spec.md", "README.md"] }
  ],
  "ignoreForAgentContext": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "*.tsbuildinfo"
  ],
  "contextBudget": {
    "claudeMdMaxWords": 1100,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
