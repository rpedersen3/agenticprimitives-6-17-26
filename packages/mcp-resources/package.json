{
  "name": "@agenticprimitives/mcp-resources",
  "version": "0.0.1",
  "description": "Delegation-aware resource access management for MCP servers. withDelegation() wrapper, JTI replay protection, classification metadata.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./lint": {
      "types": "./dist/lint.d.ts",
      "import": "./dist/lint.js"
    }
  },
  "files": ["dist", "spec.md", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf dist"
  },
  "keywords": ["mcp", "model-context-protocol", "delegation", "agentic", "authorization"],
  "license": "UNLICENSED",
  "peerDependencies": {
    "@agenticprimitives/delegation": "workspace:*"
  }
}
