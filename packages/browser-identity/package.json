{
  "name": "@agenticprimitives/browser-identity",
  "version": "1.0.0-alpha.6",
  "description": "Browser sign-in adapter seam: feature-detect FedCM and choose the browser-native path vs the guaranteed fallback. FedCM-first, not FedCM-only (ADR-0031).",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentictrustlabs/agenticprimitives.git",
    "directory": "packages/browser-identity"
  },
  "homepage": "https://github.com/agentictrustlabs/agenticprimitives/tree/master/packages/browser-identity",
  "bugs": {
    "url": "https://github.com/agentictrustlabs/agenticprimitives/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "dist",
    "spec.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "fedcm",
    "browser-identity",
    "federation",
    "sign-in",
    "adapter",
    "agentic"
  ]
}
