{
  "name": "@agenticprimitives/agent-profile",
  "version": "1.0.0-alpha.7",
  "description": "Agent identity SDK: HCS-11-aligned typed profile schema (AgentCard), HCS-14 CAIP-10 nativeId helpers, mcpServer.verification methods (DNS TXT / signed URL / HTTP challenge / VP), canonical-JSON content-hash. Speaks identity-domain vocabulary only.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentictrustlabs/agenticprimitives.git",
    "directory": "packages/agent-profile"
  },
  "homepage": "https://github.com/agentictrustlabs/agenticprimitives/tree/master/packages/agent-profile",
  "bugs": {
    "url": "https://github.com/agentictrustlabs/agenticprimitives/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./caip10": {
      "types": "./dist/caip10.d.ts",
      "import": "./dist/caip10.js"
    },
    "./profile": {
      "types": "./dist/profile.d.ts",
      "import": "./dist/profile.js"
    }
  },
  "files": [
    "LICENSE",
    "dist",
    "spec.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@agenticprimitives/agent-account": "workspace:*",
    "@agenticprimitives/connect-auth": "workspace:*",
    "@agenticprimitives/types": "workspace:*",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "agent",
    "identity",
    "hcs-11",
    "hcs-14",
    "erc-8004",
    "caip-10",
    "agentic"
  ]
}
