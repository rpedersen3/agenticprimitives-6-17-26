{
  "name": "@agenticprimitives/tool-policy",
  "version": "0.0.1",
  "description": "Protocol-agnostic classification, risk tiers, and exact-call policy. Consumable by MCP, A2A, LangGraph, and Vercel AI tool runtimes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lint": {
      "types": "./dist/lint.d.ts",
      "import": "./dist/lint.js"
    }
  },
  "files": ["dist", "spec.md", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf dist"
  },
  "keywords": ["policy", "classification", "risk-tier", "exact-call", "agentic", "tool-policy"],
  "license": "UNLICENSED",
  "peerDependencies": {
    "@agenticprimitives/types": "workspace:*"
  }
}
