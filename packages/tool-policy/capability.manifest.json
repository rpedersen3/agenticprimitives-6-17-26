{
  "name": "@agenticprimitives/tool-policy",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/204-tool-policy.md",
  "summary": "Protocol-agnostic classification taxonomy + risk tiers + exact-call DSL + decision engine. Consumable by any tool runtime.",
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": [
    "@agenticprimitives/types"
  ],
  "allowedImports": [
    "@agenticprimitives/types"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/identity-auth",
    "@agenticprimitives/agent-account",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/mcp-runtime",
    "@modelcontextprotocol/sdk",
    "@a2aproject/a2a-js",
    "langchain",
    "@langchain/core",
    "ai",
    "@vercel/ai"
  ],
  "publicExports": [
    "RiskTier",
    "ToolClassification",
    "ExactCallPolicy",
    "PolicyContext",
    "PolicyDecision",
    "CaveatContext",
    "CaveatLike",
    "DelegationLike",
    "declareTool",
    "exactCall",
    "matchesExactCall",
    "evaluatePolicy",
    "clampTtlForRiskTier",
    "requiredCaveatsForRiskTier",
    "lintClassification",
    "LintResult",
    "Address",
    "Hex"
  ],
  "forbiddenTerms": [
    { "term": "@modelcontextprotocol", "reason": "Protocol-agnostic. Importing MCP SDK violates ADR-0003.", "owningPackage": "@agenticprimitives/mcp-runtime" },
    { "term": "a2a-js", "reason": "Protocol-agnostic. ADR-0003.", "owningPackage": "future @agenticprimitives/a2a-runtime" },
    { "term": "langchain", "reason": "Protocol-agnostic. ADR-0003." },
    { "term": "@langchain", "reason": "Protocol-agnostic. ADR-0003." },
    { "term": "@vercel/ai", "reason": "Protocol-agnostic. ADR-0003." },
    { "term": "withDelegation", "reason": "MCP wrapper belongs in mcp-runtime.", "owningPackage": "@agenticprimitives/mcp-runtime" },
    { "term": "DelegationClient", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "SessionManager", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "A2AKeyProvider", "reason": "Belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "envelope encryption", "reason": "Belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "JTI", "reason": "Belongs in delegation/mcp-runtime.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "passkey", "reason": "Auth method; belongs in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth" },
    { "term": "JWT", "reason": "Session mechanism; belongs in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth", "allowInPaths": ["spec.md", "README.md"] },
    { "term": "OAuth", "reason": "Auth method; belongs in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth" }
  ],
  "ignoreForAgentContext": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "*.tsbuildinfo"
  ],
  "contextBudget": {
    "claudeMdMaxWords": 1200,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
