{
  "name": "@agenticprimitives/mcp-runtime",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/205-mcp-runtime.md",
  "summary": "Delegation-aware authorization middleware around the official MCP SDK. withDelegation/withCrossDelegation wrappers, JTI replay protection, classification routing.",
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": [
    "@agenticprimitives/types",
    "@agenticprimitives/audit",
    "@agenticprimitives/delegation",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/tool-policy"
  ],
  "allowedImports": [
    "@agenticprimitives/types",
    "@agenticprimitives/audit",
    "@agenticprimitives/delegation",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/tool-policy",
    "@modelcontextprotocol/sdk",
    "better-sqlite3",
    "pg",
    "viem"
  ],
  "forbiddenImports": [
    "apps/*"
  ],
  "publicExports": [
    "withDelegation",
    "withCrossDelegation",
    "declareResource",
    "createSqliteJtiStore",
    "createPostgresJtiStore",
    "createMemoryJtiStore",
    "verifyDelegationForResource",
    "verifyCrossDelegationForResource",
    "McpResourceVerifyConfig",
    "ResourceDefinition",
    "BetterSqlite3DatabaseLike",
    "PgPoolLike",
    "Address",
    "Hex",
    "Caveat",
    "DataScopeGrant",
    "Delegation",
    "EnforcerAddressMap",
    "JtiStore",
    "ToolClassification",
    "McpAuthError",
    "generateServiceMac",
    "verifyServiceMac",
    "bodyDigestHex",
    "MacProviderLike",
    "ServiceMacContext",
    "ServiceMacHeaders"
  ],
  "forbiddenTerms": [
    { "term": "passkey", "reason": "Auth method internals belong in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth", "allowInPaths": ["spec.md", "README.md"] },
    { "term": "SIWE", "reason": "Auth method belongs in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth", "allowInPaths": ["spec.md", "README.md"] },
    { "term": "OAuth", "reason": "Auth method belongs in identity-auth.", "owningPackage": "@agenticprimitives/identity-auth", "allowInPaths": ["spec.md", "README.md"] },
    { "term": "AgentAccountClient", "reason": "Smart-account substrate belongs in agent-account; mcp-runtime never instantiates this client directly.", "owningPackage": "@agenticprimitives/agent-account", "allowInPaths": ["spec.md", "README.md"] },
    { "term": "AgentAccountFactory", "reason": "Belongs in agent-account.", "owningPackage": "@agenticprimitives/agent-account" },
    { "term": "envelope encryption", "reason": "Belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "LocalAesProvider", "reason": "Concrete KMS backend; belongs in key-custody. Use the A2AKeyProvider interface via delegation.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "AwsKmsProvider", "reason": "Belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "GcpKmsProvider", "reason": "Belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "AES-GCM", "reason": "Encryption algorithm specifics belong in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "buildCaveat", "reason": "Caveat builders belong in delegation; mcp-runtime consumes Delegations as already-built objects.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "encodeTimestampTerms", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "RiskTier", "reason": "Belongs in tool-policy.", "owningPackage": "@agenticprimitives/tool-policy", "allowInPaths": ["spec.md", "README.md", "CLAUDE.md"] },
    { "term": "declareTool", "reason": "Classification primitive belongs in tool-policy; mcp-runtime re-exports declareResource which composes it.", "owningPackage": "@agenticprimitives/tool-policy" }
  ],
  "ignoreForAgentContext": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "*.tsbuildinfo",
    "test/fixtures/golden/**"
  ],
  "contextBudget": {
    "claudeMdMaxWords": 1300,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
