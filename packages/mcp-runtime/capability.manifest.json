{
  "name": "@agenticprimitives/mcp-runtime",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/205-mcp-runtime.md",
  "summary": "Authorization middleware around the official MCP SDK. withDelegation wrapper, JTI replay protection, classification routing. (withCrossDelegation removed in H7-B.8; resurfaces under ./experimental.)",
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": [
    "@agenticprimitives/types",
    "@agenticprimitives/audit",
    "@agenticprimitives/delegation",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/tool-policy"
  ],
  "allowedImports": [
    "@agenticprimitives/types",
    "@agenticprimitives/audit",
    "@agenticprimitives/delegation",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/tool-policy",
    "@modelcontextprotocol/sdk",
    "better-sqlite3",
    "pg",
    "viem"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/agent-naming",
    "@agenticprimitives/agent-profile",
    "@agenticprimitives/agent-relationships"
  ],
  "publicExports": [
    "withDelegation",
    "declareResource",
    "createSqliteJtiStore",
    "createPostgresJtiStore",
    "createMemoryJtiStore",
    "MigratableJtiStore",
    "verifyDelegationForResource",
    "McpResourceVerifyConfig",
    "ResourceDefinition",
    "BetterSqlite3DatabaseLike",
    "PgPoolLike",
    "Address",
    "Hex",
    "Caveat",
    "DataScopeGrant",
    "Delegation",
    "EnforcerAddressMap",
    "JtiStore",
    "ToolClassification",
    "McpAuthError",
    "generateServiceMac",
    "verifyServiceMac",
    "bodyDigestHex",
    "MacProviderLike",
    "ServiceMacContext",
    "ServiceMacHeaders"
  ],
  "forbiddenTerms": [
    {
      "term": "passkey",
      "reason": "Auth method internals belong in connect-auth. mcp-runtime may reference the term in cross-cutting-capability docstrings (spec 207 UV gate is a passkey concept).",
      "owningPackage": "@agenticprimitives/connect-auth",
      "allowInPaths": ["src/with-delegation.ts", "spec.md", "README.md", "CLAUDE.md", "AUDIT.md"]
    },
    {
      "term": "SIWE",
      "reason": "Auth method belongs in connect-auth.",
      "owningPackage": "@agenticprimitives/connect-auth",
      "allowInPaths": ["spec.md", "README.md"]
    },
    {
      "term": "OAuth",
      "reason": "Auth method belongs in connect-auth.",
      "owningPackage": "@agenticprimitives/connect-auth",
      "allowInPaths": ["spec.md", "README.md"]
    },
    {
      "term": "AgentAccountClient",
      "reason": "Smart-account substrate belongs in agent-account; mcp-runtime never instantiates this client directly.",
      "owningPackage": "@agenticprimitives/agent-account",
      "allowInPaths": ["spec.md", "README.md"]
    },
    {
      "term": "AgentAccountFactory",
      "reason": "Belongs in agent-account.",
      "owningPackage": "@agenticprimitives/agent-account"
    },
    {
      "term": "envelope encryption",
      "reason": "Belongs in key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "LocalAesProvider",
      "reason": "Concrete KMS backend; belongs in key-custody. Use the A2AKeyProvider interface via delegation.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "AwsKmsProvider",
      "reason": "Belongs in key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "GcpKmsProvider",
      "reason": "Belongs in key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "AES-GCM",
      "reason": "Encryption algorithm specifics belong in key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "buildCaveat",
      "reason": "Caveat builders belong in delegation; mcp-runtime consumes Delegations as already-built objects.",
      "owningPackage": "@agenticprimitives/delegation"
    },
    {
      "term": "encodeTimestampTerms",
      "reason": "Belongs in delegation.",
      "owningPackage": "@agenticprimitives/delegation"
    },
    {
      "term": "RiskTier",
      "reason": "Belongs in tool-policy.",
      "owningPackage": "@agenticprimitives/tool-policy",
      "allowInPaths": ["spec.md", "README.md", "CLAUDE.md"]
    },
    {
      "term": "declareTool",
      "reason": "Classification primitive belongs in tool-policy; mcp-runtime re-exports declareResource which composes it.",
      "owningPackage": "@agenticprimitives/tool-policy",
      "allowInPaths": ["src/with-delegation.ts"]
    }
  ],
  "ignoreForAgentContext": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "*.tsbuildinfo",
    "test/fixtures/golden/**"
  ],
  "contextBudget": {
    "claudeMdMaxWords": 1300,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
