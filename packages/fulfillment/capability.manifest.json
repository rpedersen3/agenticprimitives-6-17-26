{
  "name": "@agenticprimitives/fulfillment",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/244-fulfillment.md",
