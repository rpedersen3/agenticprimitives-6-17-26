{
  "name": "@agenticprimitives/types",
  "version": "1.0.0-alpha.10",
  "description": "Cross-cutting branded types and chain primitives shared across @agenticprimitives/* packages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentictrustlabs/agenticprimitives.git",
    "directory": "packages/types"
  },
  "homepage": "https://github.com/agentictrustlabs/agenticprimitives/tree/master/packages/types",
  "bugs": {
    "url": "https://github.com/agentictrustlabs/agenticprimitives/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "dist",
    "spec.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "types",
    "agentic"
  ]
}
