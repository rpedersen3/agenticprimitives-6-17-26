{
  "name": "@agenticprimitives/types",
  "kind": "shared",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/101-v0-package-proposal.md",
  "summary": "Cross-cutting branded types: Address, Hex, ChainId, BrandedId, plus the NameContext / AgentType shapes downstream packages accept as injected naming context (ADR-0006). Types-only; no runtime code.",
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": [],
  "allowedImports": [],
  "forbiddenImports": ["apps/*", "@agenticprimitives/*"],
  "publicExports": ["Address", "Hex", "ChainId", "BrandedId", "AgentType", "NameContext"],
  "forbiddenTerms": [
    {
      "term": "Delegation",
      "reason": "Domain concept; types-only package has no domain types.",
      "owningPackage": "@agenticprimitives/delegation",
      "allowInPaths": ["src/index.ts"]
    },
    {
      "term": "Signer",
      "reason": "Belongs in identity-auth.",
      "owningPackage": "@agenticprimitives/identity-auth"
    },
    {
      "term": "AccountClient",
      "reason": "Belongs in agent-account.",
      "owningPackage": "@agenticprimitives/agent-account"
    },
    {
      "term": "KMS",
      "reason": "Belongs in key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "RiskTier",
      "reason": "Belongs in tool-policy.",
      "owningPackage": "@agenticprimitives/tool-policy"
    }
  ],
  "ignoreForAgentContext": ["dist/**", "node_modules/**", "coverage/**", "*.tsbuildinfo"],
  "contextBudget": {
    "claudeMdMaxWords": 900,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
