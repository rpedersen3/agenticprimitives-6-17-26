{
  "name": "@agenticprimitives/intent-resolver",
  "version": "0.0.0-alpha.3",
  "description": "Resolver layer skeleton (W1) — types + PassThroughResolver only. Full resolver engine deferred to W2.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentictrustlabs/agenticprimitives.git",
    "directory": "packages/intent-resolver"
  },
  "homepage": "https://github.com/agentictrustlabs/agenticprimitives/tree/master/packages/intent-resolver",
  "bugs": {
    "url": "https://github.com/agentictrustlabs/agenticprimitives/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "dist",
    "spec.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "vitest": "^4.1.8",
    "viem": "^2.52.2"
  },
  "keywords": [
    "agentic",
    "primitives",
    "intent-resolver"
  ],
  "dependencies": {
    "@agenticprimitives/types": "workspace:*",
    "@agenticprimitives/verifiable-credentials": "workspace:*",
    "@noble/hashes": "^2.2.0"
  }
}
