{
  "name": "@agenticprimitives/a2a",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/269-async-delegation-authorized-a2a.md",
  "summary": "Async, delegation-authorized Agent-to-Agent task transport (spec 269): Task runtime + SkillHandler dispatch, delegation-auth gate, scoped grants, JSON-RPC + client, push + SSE, Cloudflare DO adapter.",
  "capabilities": [
    "async-task-transport",
    "task-lifecycle-runtime",
    "skill-handler-dispatch",
    "delegation-authorized-messaging",
    "scoped-grant-caveats"
  ],
  "runtime": [
    "browser",
    "node",
    "worker"
  ],
  "readFirst": [
    "CLAUDE.md",
    "README.md",
    "src/index.ts"
  ],
  "docs": {},
  "validation": [
    "pnpm --filter @agenticprimitives/a2a typecheck",
    "pnpm --filter @agenticprimitives/a2a test",
    "pnpm check:public-exports",
    "pnpm check:no-domain-in-packages"
  ],
  "securityInvariants": [
    "every task transition is fail-closed via canTaskTransition; unknown skill -> rejected",
    "no task is created for an unverifiable grant (W2 auth gate)",
    "task.permissionGrantRef binds every task to hashDelegation(grant); revoke fails in-flight closed",
    "message + artifact bodies live in the vault (VaultRef); only hashes/refs in task state",
    "the core ships NO Cloudflare coupling — the DurableObject is the ./cloudflare adapter (ADR-0034)",
    "no long-lived signing key for a claimed agent; KMS/session signer only"
  ],
  "integrationPoints": {
    "consumes": [
      "@agenticprimitives/types",
      "@agenticprimitives/fulfillment",
      "@agenticprimitives/delegation"
    ],
    "mustNotImport": [
      "@agenticprimitives/mcp-runtime",
      "@agenticprimitives/tool-policy",
      "@modelcontextprotocol/sdk"
    ]
  },
  "owns": {
    "source": [
      "src/**"
    ],
    "tests": [
      "test/**"
    ]
  },
  "imports": [
    "@agenticprimitives/types",
    "@agenticprimitives/fulfillment",
    "@agenticprimitives/delegation",
    "viem"
  ],
  "allowedImports": [
    "@agenticprimitives/types",
    "@agenticprimitives/fulfillment",
    "@agenticprimitives/delegation",
    "viem"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/mcp-runtime",
    "@agenticprimitives/tool-policy",
    "@agenticprimitives/agent-naming",
    "@agenticprimitives/agent-profile",
    "@agenticprimitives/agent-relationships",
    "@modelcontextprotocol/sdk"
  ],
  "publicExports": [
