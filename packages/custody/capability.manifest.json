  "forbiddenTerms": [
    {
      "term": "Steward",
      "reason": "Agency-layer concept. Belongs in @agenticprimitives/delegation.",
      "owningPackage": "@agenticprimitives/delegation",
      "allowInPaths": ["CLAUDE.md", "src/index.ts"]
    },
    {
      "term": "Caveat",
      "reason": "Delegation caveats are agency-layer permissions.",
      "owningPackage": "@agenticprimitives/delegation",
      "allowInPaths": ["CLAUDE.md", "src/index.ts"]
    },
    {
      "term": "MCP",
      "reason": "Transport concerns belong in @agenticprimitives/mcp-runtime or apps.",
      "owningPackage": "@agenticprimitives/mcp-runtime"
    },
    {
      "term": "KMS",
      "reason": "Key custody is separate from account custody.",
      "owningPackage": "@agenticprimitives/key-custody",
      "allowInPaths": ["CLAUDE.md"]
    }
  ],
  "ignoreForAgentContext": ["dist/**", "node_modules/**", "coverage/**", "*.tsbuildinfo"],
  "contextBudget": {
    "claudeMdMaxWords": 900,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
