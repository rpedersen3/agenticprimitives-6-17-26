{
  "name": "@agenticprimitives/identity-directory-adapters",
  "version": "1.0.0-alpha.10",
  "description": "Port implementations for @agenticprimitives/identity-directory: NamingPort (wraps agent-naming), OnChainReadPort (viem readContract), IndexerPort (in-memory; SPARQL/GraphDB later). The one composition layer allowed to import agent-naming (spec 100 §4 / ADR-0015).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentictrustlabs/agenticprimitives.git",
    "directory": "packages/identity-directory-adapters"
  },
  "homepage": "https://github.com/agentictrustlabs/agenticprimitives/tree/master/packages/identity-directory-adapters",
  "bugs": {
    "url": "https://github.com/agentictrustlabs/agenticprimitives/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "dist",
    "spec.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit --passWithNoTests",
    "test:integration": "vitest run test/integration --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@agenticprimitives/agent-naming": "workspace:*",
    "@agenticprimitives/identity-directory": "workspace:*",
    "@agenticprimitives/types": "workspace:*",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "vitest": "^4.1.8"
  },
  "keywords": [
    "identity",
    "directory",
    "adapters",
    "ports",
    "agentic"
  ]
}
