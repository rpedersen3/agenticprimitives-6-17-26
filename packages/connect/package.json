{
  "name": "@agenticprimitives/connect",
  "version": "1.0.0-alpha.10",
  "description": "Agentic Connect — the SSO broker (spec 224 / ADR-0014). Mints CAIP-10-subject, no-owner AgentSessions (asymmetric + JWKS); drives entry-flow convergence (connect-auth verify → identity-directory resolve → issue/bootstrap/disambiguate) with assurance floor, non-EVM gate, and code-exchange redirect security.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentictrustlabs/agenticprimitives.git",
    "directory": "packages/connect"
  },
  "homepage": "https://github.com/agentictrustlabs/agenticprimitives/tree/master/packages/connect",
  "bugs": {
    "url": "https://github.com/agentictrustlabs/agenticprimitives/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "dist",
    "spec.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit --passWithNoTests",
    "test:integration": "vitest run test/integration --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@agenticprimitives/connect-auth": "workspace:*",
    "@agenticprimitives/identity-directory": "workspace:*",
    "@agenticprimitives/types": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.8"
  },
  "keywords": [
    "sso",
    "broker",
    "agentsession",
    "jwks",
    "agentic"
  ]
}
