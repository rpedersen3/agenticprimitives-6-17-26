    "@agenticprimitives/mcp-runtime",
    "@agenticprimitives/tool-policy"
  ],
  "publicExports": [
    "buildRelatedAgentCredential",
    "relatedAgentProofHash",
    "relatedAgentReadCaveats",
    "RELATED_AGENT_DESCRIPTION",
    "RelatedAgentCredential",
    "RelatedAgentLink",
    "ListRelatedAgentsResponse",
    "ListDelegatedAgentsResponse"
