{
  "name": "@agenticprimitives/related-agents",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/246-related-agents-vault.md",
