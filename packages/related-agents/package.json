{
  "name": "@agenticprimitives/related-agents",
  "version": "0.0.0-alpha.4",
  "description": "Private, holder-resident related-agent credentials (person↔org links as vault situation credentials, never on-chain edges — ADR-0025) + scoped-delegation read caveats + list-query shapes. Composes verifiable-credentials + delegation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentictrustlabs/agenticprimitives.git",
    "directory": "packages/related-agents"
  },
  "homepage": "https://github.com/agentictrustlabs/agenticprimitives/tree/master/packages/related-agents",
  "bugs": {
    "url": "https://github.com/agentictrustlabs/agenticprimitives/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "dist",
    "spec.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "vitest": "^4.1.8",
    "viem": "^2.52.2"
  },
  "keywords": [
    "agentic",
    "primitives",
    "related-agents",
    "vault"
  ],
  "dependencies": {
    "@agenticprimitives/delegation": "workspace:*",
    "@agenticprimitives/types": "workspace:*",
    "@agenticprimitives/verifiable-credentials": "workspace:*"
  }
}
