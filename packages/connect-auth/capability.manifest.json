{
  "name": "@agenticprimitives/connect-auth",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/200-connect-auth.md",
  "summary": "User auth (passkey + SIWE + Google OAuth), JWT sessions, CSRF, and pluggable Signer interfaces consumed by agent-account and delegation.",
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": [
    "@agenticprimitives/types"
  ],
  "allowedImports": [
    "@agenticprimitives/types",
    "viem",
    "@noble/curves",
    "@noble/hashes"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/agent-account",
    "@agenticprimitives/delegation",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/tool-policy",
    "@agenticprimitives/mcp-runtime"
  ],
  "publicExports": [
    "mintSession",
    "verifySession",
    "SESSION_COOKIE",
    "SESSION_TTL_SECONDS",
    "csrfTokenFor",
    "verifyCsrf",
    "deriveSaltFromLabel",
    "deriveSaltFromEmail",
    "Signer",
    "PasskeySigner",
    "PasskeyAssertion",
    "EOASigner",
    "KMSSigner",
    "TypedDataDomain",
    "TypedDataTypes",
    "JwtClaims",
    "AuthenticatedUser",
    "AuthMethod",
    "Address",
    "Hex",
    "ERC1271_MAGIC",
    "ERC6492_MAGIC",
    "universalSignatureValidatorAbi",
    "verifyUserSignature",
    "verifyUserSignatureView",
    "isErc6492Wrapped",
    "VerifyUserSignatureArgs",
    "UniversalValidatorClient",
    "P256_N",
    "base64urlEncode",
    "base64urlDecode",
    "parseDerSignature",
    "normaliseLowS",
    "buildWebAuthnAssertion",
    "hashToWebAuthnChallenge",
    "parseAttestationObject",
    "parseAuthData",
    "WebAuthnAssertion",
    "ParsedAttestation"
  ],
  "forbiddenTerms": [
    { "term": "Delegation", "reason": "Authority concept; this package authenticates identity, not authority.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "Caveat", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "Enforcer", "reason": "Belongs in delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "SessionManager", "reason": "Lifecycle owned by delegation; this package's 'session' is the JWT-cookie session, a different concept.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "SessionRow", "reason": "Session-row shape is delegation's vocabulary.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "envelope encryption", "reason": "Crypto primitive; belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "A2AKeyProvider", "reason": "Belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "JTI", "reason": "Belongs in delegation (semantics) and mcp-runtime (storage).", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "MCP", "reason": "Belongs in mcp-runtime; identity-auth is transport-free.", "owningPackage": "@agenticprimitives/mcp-runtime", "allowInPaths": ["spec.md", "README.md"] }
  ],
  "ignoreForAgentContext": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "*.tsbuildinfo"
  ],
  "contextBudget": {
    "claudeMdMaxWords": 1200,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
