    { "term": "AwsKmsProvider", "reason": "Concrete KMS backend belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "GcpKmsProvider", "reason": "Concrete KMS backend belongs in key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "AES-GCM", "reason": "Encryption algorithm specifics belong in key-custody. Permitted in session-manager.ts (the documented bridge: delegation drives the payload-layer encryption using a data key from key-custody; v0.1 may push this primitive into key-custody itself).", "owningPackage": "@agenticprimitives/key-custody", "allowInPaths": ["src/session-manager.ts", "test/integration/session-manager.test.ts", "spec.md", "README.md", "CLAUDE.md"] },
    { "term": "AAD", "reason": "AAD shape is delegation's choice but AAD encoding is key-custody's. Permitted in session-manager.ts as parameter names + comments.", "owningPackage": "@agenticprimitives/key-custody", "allowInPaths": ["src/session-manager.ts", "test/integration/session-manager.test.ts", "spec.md", "README.md", "CLAUDE.md"] },
    { "term": "RiskTier", "reason": "Policy taxonomy belongs in tool-policy. Consume requiredCaveatsForRiskTier from there; don't redefine levels.", "owningPackage": "@agenticprimitives/tool-policy", "allowInPaths": ["spec.md", "README.md"] },
