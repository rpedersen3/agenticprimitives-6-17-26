{
  "name": "@agenticprimitives/agent-naming",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/215-agent-naming.md",
  "summary": "ENS-v2-style hierarchical names for Smart Agents (.agent TLD). Pure helpers + record schemas + client skeleton. Phase 1: SDK only.",
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": [
    "@agenticprimitives/types",
    "@agenticprimitives/identity-auth",
    "@agenticprimitives/agent-account",
    "viem"
  ],
  "allowedImports": [
    "@agenticprimitives/types",
    "@agenticprimitives/identity-auth",
    "@agenticprimitives/agent-account",
    "viem",
    "@noble/hashes"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/delegation",
    "@agenticprimitives/mcp-runtime",
    "@agenticprimitives/tool-policy",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/audit",
    "@agenticprimitives/custody",
    "@modelcontextprotocol/sdk"
  ],
  "publicExports": [
    "AGENT_TLD",
    "AgentTld",
    "normalizeAgentName",
    "isValidAgentName",
    "labelhash",
    "namehash",
    "ZERO_NODE",
    "AgentKind",
    "AgentNameRecords",
    "AgentNamingClient",
    "AgentNamingClientOpts",
    "InvalidNameError",
    "NameNotFoundError",
    "UnauthorizedNameOwnerError",
    "RegisterSubnameInput",
    "SetPrimaryNameInput",
    "SetAgentRecordsInput",
    "SetSubregistryInput",
    "agentNameRegistryAbi",
    "agentNameAttributeResolverAbi",
    "agentNameUniversalResolverAbi",
    "ontologyTermRegistryAbi",
    "shapeRegistryAbi",
    "PREDICATE_ID",
    "AGENT_KIND_ID",
    "CLASS_AGENT_NAME",
    "AGENT_KIND_ENUM",
    "CAIP10_NAMESPACE_ALLOWLIST",
    "encodeRecords",
    "decodeRecords",
    "PredicateName",
    "EncodedRecord",
    "DecodeInput"
  ],
  "forbiddenTerms": [
    { "term": "Delegation", "reason": "Belongs in @agenticprimitives/delegation. Naming-domain only.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "Caveat", "reason": "Belongs in @agenticprimitives/delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "Steward", "reason": "Belongs in @agenticprimitives/delegation.", "owningPackage": "@agenticprimitives/delegation" },
    { "term": "Custodian", "reason": "Belongs in @agenticprimitives/custody. Compose via agent-naming/custody subpath builders without import.", "owningPackage": "@agenticprimitives/custody" },
    { "term": "Trustee", "reason": "Belongs in @agenticprimitives/custody.", "owningPackage": "@agenticprimitives/custody" },
    { "term": "RiskTier", "reason": "Belongs in @agenticprimitives/tool-policy.", "owningPackage": "@agenticprimitives/tool-policy" },
    { "term": "KMS", "reason": "Belongs in @agenticprimitives/key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "AAD", "reason": "Belongs in @agenticprimitives/key-custody.", "owningPackage": "@agenticprimitives/key-custody" },
    { "term": "JtiStore", "reason": "Belongs in @agenticprimitives/mcp-runtime.", "owningPackage": "@agenticprimitives/mcp-runtime" }
  ],
  "ignoreForAgentContext": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "*.tsbuildinfo"
  ],
  "contextBudget": {
    "claudeMdMaxWords": 900,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
