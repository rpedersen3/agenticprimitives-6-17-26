{
  "name": "@agenticprimitives/agent-naming",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/215-agent-naming.md",
  "summary": "Hierarchical names for Smart Agents (.agent TLD). Pure helpers + record schemas + client skeleton. Phase 1: SDK only.",
  "capabilities": [
    "name-resolution",
    "reverse-resolution",
    "service-discovery",
    "typed-record-encoding",
    "name-management-call-builders"
  ],
  "runtime": ["browser", "node", "worker"],
  "readFirst": ["CLAUDE.md", "README.md", "src/index.ts", "docs/concepts.md", "docs/api.md"],
  "docs": {
    "concepts": "docs/concepts.md",
    "api": "docs/api.md",
    "security": "docs/security.md",
    "troubleshooting": "docs/troubleshooting.md",
    "migration": "docs/migration.md",
    "audit": "AUDIT.md"
  },
  "examples": ["examples/basic.ts", "examples/records.ts", "examples/custody-rotation.ts"],
  "validation": [
    "pnpm check:agent-naming",
    "pnpm check:public-exports",
    "pnpm check:forbidden-terms"
  ],
  "securityInvariants": [
    "name normalization must be deterministic",
    "reverse resolution must round-trip",
    "unknown predicates must fail closed on read and fail loud on write",
    "raw passkey credential IDs must never be stored",
    "endpoint records are discovery hints, not proof of endpoint control"
  ],
  "integrationPoints": {
    "consumes": [
      "@agenticprimitives/types",
      "@agenticprimitives/connect-auth",
      "@agenticprimitives/agent-account"
    ],
    "mustNotImport": [
      "@agenticprimitives/delegation",
      "@agenticprimitives/account-custody",
      "@agenticprimitives/mcp-runtime",
      "@agenticprimitives/key-custody"
    ]
  },
  "owns": {
    "source": ["src/**"],
    "tests": ["test/**"]
  },
  "imports": [
    "@agenticprimitives/types",
    "@agenticprimitives/connect-auth",
    "@agenticprimitives/agent-account",
    "viem"
  ],
  "allowedImports": [
    "@agenticprimitives/types",
    "@agenticprimitives/connect-auth",
    "@agenticprimitives/agent-account",
    "viem",
    "@noble/hashes"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/delegation",
    "@agenticprimitives/mcp-runtime",
    "@agenticprimitives/tool-policy",
    "@agenticprimitives/key-custody",
    "@agenticprimitives/audit",
    "@agenticprimitives/account-custody",
    "@agenticprimitives/agent-profile",
    "@agenticprimitives/agent-relationships",
    "@modelcontextprotocol/sdk"
  ],
  "publicExports": [
    "AGENT_TLD",
    "AgentTld",
    "normalizeAgentName",
    "isValidAgentName",
    "labelhash",
    "namehash",
    "ZERO_NODE",
    "AgentKind",
    "AgentNameRecords",
    "AgentNamingClient",
    "AgentNamingClientOpts",
    "InvalidNameError",
    "NameNotFoundError",
    "UnauthorizedNameOwnerError",
    "RegisterSubnameInput",
    "SetPrimaryNameInput",
    "SetAgentRecordsInput",
    "SetSubregistryInput",
    "agentNameRegistryAbi",
    "agentNameAttributeResolverAbi",
    "agentNameUniversalResolverAbi",
    "ontologyTermRegistryAbi",
    "shapeRegistryAbi",
    "PREDICATE_ID",
    "AGENT_KIND_ID",
    "CLASS_AGENT_NAME",
    "AGENT_KIND_ENUM",
    "CAIP10_NAMESPACE_ALLOWLIST",
    "encodeRecords",
    "decodeRecords",
    "PredicateName",
    "EncodedRecord",
    "DecodeInput",
    "WriteContext",
    "ContractCall",
    "buildRegisterSubnameCall",
    "buildRotateNameOwnerCall",
    "buildRotateNameResolverCall",
    "buildSetSubregistryCall",
    "buildSetPrimaryNameCall",
    "buildSetStringAttributeCall",
    "buildSetAddressAttributeCall",
    "buildSetBytes32AttributeCall",
    "buildRecordCalls",
    "buildSubregistryRegisterCall",
    "permissionlessSubregistryAbi"
  ],
  "forbiddenTerms": [
    {
      "term": "Delegation",
      "reason": "Belongs in @agenticprimitives/delegation. Naming-domain only.",
      "owningPackage": "@agenticprimitives/delegation"
    },
    {
      "term": "Caveat",
      "reason": "Belongs in @agenticprimitives/delegation.",
      "owningPackage": "@agenticprimitives/delegation"
    },
    {
      "term": "Steward",
      "reason": "Belongs in @agenticprimitives/delegation.",
      "owningPackage": "@agenticprimitives/delegation"
    },
    {
      "term": "Custodian",
      "reason": "Belongs in @agenticprimitives/account-custody. Compose via agent-naming/custody subpath builders without import.",
      "owningPackage": "@agenticprimitives/account-custody"
    },
    {
      "term": "Trustee",
      "reason": "Belongs in @agenticprimitives/account-custody.",
      "owningPackage": "@agenticprimitives/account-custody"
    },
    {
      "term": "RiskTier",
      "reason": "Belongs in @agenticprimitives/tool-policy.",
      "owningPackage": "@agenticprimitives/tool-policy"
    },
    {
      "term": "KMS",
      "reason": "Belongs in @agenticprimitives/key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "AAD",
      "reason": "Belongs in @agenticprimitives/key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "JtiStore",
      "reason": "Belongs in @agenticprimitives/mcp-runtime.",
      "owningPackage": "@agenticprimitives/mcp-runtime"
    }
  ],
  "ignoreForAgentContext": ["dist/**", "node_modules/**", "coverage/**", "*.tsbuildinfo"],
  "contextBudget": {
    "claudeMdMaxWords": 900,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
