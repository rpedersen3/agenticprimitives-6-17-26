{
  "name": "@agenticprimitives/attestations",
  "kind": "capability",
  "stability": "experimental",
  "agentEntry": "CLAUDE.md",
  "publicEntry": "src/index.ts",
  "specEntry": "../../specs/242-trust-credentials-and-public-assertions.md",
  "summary": "AttestationRegistry SDK (EAS-aligned, bilateral-consent) — Association + JointAgreement + Evidence + Outcome + Validation + TrustUpdate credential types in one on-chain registry per ADR-0023.",
  "spineLayers": [
    12,
    13,
    14,
    15
  ],
  "owns": {
    "source": [
      "src/**"
    ],
    "tests": [
      "test/**"
    ],
    "shapes": [
      "src/shapes/credentials.shacl.ttl"
    ]
  },
  "imports": [
    "@agenticprimitives/types",
    "@agenticprimitives/verifiable-credentials",
    "@agenticprimitives/delegation"
  ],
  "allowedImports": [
    "@agenticprimitives/types",
    "@agenticprimitives/verifiable-credentials",
    "@agenticprimitives/delegation",
    "@agenticprimitives/ontology",
    "viem",
    "@noble/hashes"
  ],
  "forbiddenImports": [
    "apps/*",
    "@agenticprimitives/intent-marketplace",
    "@agenticprimitives/intent-resolver",
    "@agenticprimitives/payments",
    "@agenticprimitives/fulfillment",
    "@agenticprimitives/agreements",
    "@agenticprimitives/agent-naming",
    "@agenticprimitives/agent-profile",
    "@agenticprimitives/agent-relationships"
  ],
  "forbiddenTerms": [
    {
      "term": "@modelcontextprotocol",
      "reason": "Transport-specific; this spine package is transport-agnostic (MCP/A2A wiring lives in mcp-runtime and apps).",
      "owningPackage": "@agenticprimitives/mcp-runtime"
    },
    {
      "term": "LocalAesProvider",
      "reason": "Concrete KMS backend belongs in key-custody. Consume the A2AKeyProvider interface, not a provider class.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "AwsKmsProvider",
      "reason": "Concrete KMS backend belongs in key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    },
    {
      "term": "GcpKmsProvider",
      "reason": "Concrete KMS backend belongs in key-custody.",
      "owningPackage": "@agenticprimitives/key-custody"
    }
  ],
  "publicExports": [
    "PACKAGE_NAME",
    "PACKAGE_STATUS",
    "SPEC_REF",
    "Hex32",
    "CREDENTIAL_TYPE",
    "computeAttestationUid",
    "JOINT_CONSENT_TYPEHASH",
    "jointConsentDigest",
    "AssociationAttestationRequest",
    "JointAgreementAttestationRequest"
  ],
  "ignoreForAgentContext": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "*.tsbuildinfo"
  ],
  "contextBudget": {
    "claudeMdMaxWords": 1500,
    "readmeMaxWords": 1800,
    "architectureMaxWords": 3000
  }
}
