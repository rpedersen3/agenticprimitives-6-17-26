{
  "name": "agenticprimitives",
  "version": "0.0.1",
  "private": true,
  "description": "Composable primitives for agentic web apps: auth + smart accounts, delegation, KMS, and MCP resource access.",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:web": "pnpm --filter @agenticprimitives-demo/web dev",
    "dev:a2a": "pnpm --filter @agenticprimitives-demo/a2a dev",
    "dev:mcp": "pnpm --filter @agenticprimitives-demo/mcp dev",
    "dev:contracts": "cd apps/contracts && pnpm deploy:anvil",
    "setup:contracts": "cd apps/contracts && bash setup.sh && pnpm build",
    "deploy:cloudflare": "tsx scripts/deploy-cloudflare.ts",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r --parallel --no-bail --filter './packages/*' run test:unit",
    "test:integration:packages": "pnpm -r --parallel --no-bail --filter './packages/*' run test:integration",
    "test:contracts": "cd apps/contracts && forge test",
    "test:e2e": "pnpm --filter @agenticprimitives-demo/e2e test",
    "test:e2e:ui": "pnpm --filter @agenticprimitives-demo/e2e test:ui",
    "test:e2e:debug": "pnpm --filter @agenticprimitives-demo/e2e test:debug",
    "test:e2e:install": "pnpm --filter @agenticprimitives-demo/e2e install:browsers",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "check:capability-manifests": "tsx scripts/check-capability-manifests.ts",
    "check:package-docs": "tsx scripts/check-package-docs.ts",
    "check:package-boundaries": "tsx scripts/check-package-boundaries.ts",
    "check:public-exports": "tsx scripts/check-public-exports.ts",
    "check:claude-context-budget": "tsx scripts/check-claude-context-budget.ts",
    "check:forbidden-terms": "tsx scripts/check-forbidden-terms.ts",
    "check:no-app-private-keys": "tsx scripts/check-no-app-private-keys.ts",
    "check:production-deploy": "tsx scripts/check-production-deploy.ts",
    "check:supply-chain": "tsx scripts/audit-supply-chain.ts",
    "check:cross-cutting-capabilities": "tsx scripts/check-cross-cutting-capabilities.ts",
    "check:sentinel-enforcers": "tsx scripts/check-sentinel-enforcers.ts",
    "check:all": "pnpm check:capability-manifests && pnpm check:package-docs && pnpm check:package-boundaries && pnpm check:public-exports && pnpm check:claude-context-budget && pnpm check:forbidden-terms && pnpm check:no-app-private-keys && pnpm check:cross-cutting-capabilities && pnpm check:sentinel-enforcers && pnpm check:supply-chain",
    "check:types": "pnpm --filter @agenticprimitives/types typecheck && pnpm --filter @agenticprimitives/types test",
    "check:identity-auth": "pnpm --filter @agenticprimitives/identity-auth typecheck && pnpm --filter @agenticprimitives/identity-auth test",
    "check:agent-account": "pnpm --filter @agenticprimitives/agent-account typecheck && pnpm --filter @agenticprimitives/agent-account test",
    "check:custody": "pnpm --filter @agenticprimitives/custody typecheck && pnpm --filter @agenticprimitives/custody test",
    "check:delegation": "pnpm --filter @agenticprimitives/delegation typecheck && pnpm --filter @agenticprimitives/delegation test",
    "check:key-custody": "pnpm --filter @agenticprimitives/key-custody typecheck && pnpm --filter @agenticprimitives/key-custody test",
    "check:tool-policy": "pnpm --filter @agenticprimitives/tool-policy typecheck && pnpm --filter @agenticprimitives/tool-policy test",
    "check:mcp-runtime": "pnpm --filter @agenticprimitives/mcp-runtime typecheck && pnpm --filter @agenticprimitives/mcp-runtime test",
    "check:audit": "pnpm --filter @agenticprimitives/audit typecheck && pnpm --filter @agenticprimitives/audit test",
    "check:agent-naming": "pnpm --filter @agenticprimitives/agent-naming typecheck && pnpm --filter @agenticprimitives/agent-naming test:unit",
    "check:agent-identity": "pnpm --filter @agenticprimitives/agent-identity typecheck && pnpm --filter @agenticprimitives/agent-identity test",
    "check:agent-relationships": "pnpm --filter @agenticprimitives/agent-relationships typecheck && pnpm --filter @agenticprimitives/agent-relationships test",
    "generate:capability-index": "tsx scripts/generate-capability-index.ts",
    "bootstrap:demo-names": "tsx scripts/bootstrap-demo-names.ts"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "viem": "^2.21.0",
    "@vitest/coverage-v8": "^2.1.0",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
