# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Playwright
playwright-report/
test-results/

# Foundry cache
broadcast/
out/
cache/

# Env / secrets
.env
.env.local
.env.*.local
.dev.vars
*.key
*.pem

# Wrangler local state (DO storage, D1 SQLite)
.wrangler/

# Cloudflare deploy-state file written by scripts/deploy-cloudflare.ts
cloudflare-urls.json

# GCP service-account JSON used by scripts/set-cloudflare-secrets.sh
# (piped to `wrangler secret put GCP_SERVICE_ACCOUNT_JSON --env production`
# and then shredded). Never commit.
.gcp-service-account.local.json

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
# Windows NTFS alternative data stream sidecars (created by browser downloads via WSL)
*:Zone.Identifier

# Editor
.vscode/
.idea/
*.swp

