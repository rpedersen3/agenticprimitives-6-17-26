# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Stray compile outputs inside test/ — some toolchains emit .js/.d.ts
# next to .ts when a package's tsconfig has emit enabled and the
# runner ignores --noEmit. Never commit these.
packages/*/test/**/*.js
packages/*/test/**/*.js.map
packages/*/test/**/*.d.ts
packages/*/test/**/*.d.ts.map

# Playwright
playwright-report/
test-results/

# Foundry cache
broadcast/
out/
cache/

# Env / secrets
.env
.env.local
.env.*.local
.dev.vars
*.key
*.pem

# Wrangler local state (DO storage, D1 SQLite)
.wrangler/

# Cloudflare deploy-state file written by scripts/deploy-cloudflare.ts
cloudflare-urls.json

# GCP service-account JSON used by scripts/set-cloudflare-secrets.sh
# (piped to `wrangler secret put GCP_SERVICE_ACCOUNT_JSON --env production`
# and then shredded). Never commit.
.gcp-service-account.local.json

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
# Windows NTFS alternative data stream sidecars (created by browser downloads via WSL)
*:Zone.Identifier

# Editor
.vscode/
.idea/
*.swp

# Local databases / fixtures
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Temp
.tmp/
tmp/
output/
test-results/
playwright-report/

# Coverage
coverage/
.nyc_output/

# Playwright live-demo recording artifacts
tests/e2e/recordings/

# Claude Code transient runtime locks
.claude/scheduled_tasks.lock
