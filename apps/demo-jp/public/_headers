# EXT-001 — Cloudflare Pages headers baseline for demo-jp. Same defensive shape as
# demo-sso-next's next.config.mjs. Closes the cheap clickjacking / MIME-sniff /
# referrer-leak / permissions-API surfaces. A strict CSP with nonces lands in a
# follow-up wave (the JP-side SPA has runtime-built inline styles + dynamic
# delegation flows that need careful nonce wiring before a tight CSP won't break
# the live ceremony).

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  X-DNS-Prefetch-Control: off
  Cross-Origin-Opener-Policy: same-origin-allow-popups
