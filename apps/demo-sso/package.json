{
  "name": "@agenticprimitives-demo/sso",
  "version": "0.0.1",
  "private": true,
  "description": "Agentic Connect SSO demo: enroll one credential at the Connect origin, sign in across two relying sites (one-enroll SSO), with a step-up gate for custody-class actions. Wires connect + identity-directory + adapters end-to-end (spec 224).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agenticprimitives/connect": "workspace:*",
    "@agenticprimitives/connect-auth": "workspace:*",
    "@agenticprimitives/identity-directory": "workspace:*",
    "@agenticprimitives/identity-directory-adapters": "workspace:*",
    "@agenticprimitives/types": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
