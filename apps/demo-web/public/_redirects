# Cloudflare Pages routing.
#
# Forward /a2a/<path> to the demo-a2a Worker. The exact hostname is set at
# deploy time — use a workers.dev URL during early testing, then a custom
# domain when wired through Cloudflare DNS.
#
# In local dev, vite.config.ts's proxy handles /a2a/* (no _redirects needed).
#
# Replace DEMO_A2A_HOST with your demo-a2a Worker hostname before deploy:
#   /a2a/*    https://demo-a2a.<your-subdomain>.workers.dev/:splat   200

/a2a/*    https://demo-a2a.workers.dev/:splat    200
