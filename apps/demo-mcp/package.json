{
  "name": "@agenticprimitives-demo/mcp",
  "version": "0.0.2-alpha.7",
  "private": true,
  "description": "Demo MCP server: Cloudflare Worker + D1 for profiles + JTI replay. Person-repository with delegation-verified get_profile tool.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8788 --persist-to ../../.wrangler/state-mcp",
    "deploy": "wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply demo-mcp --local --persist-to ../../.wrangler/state-mcp",
    "d1:migrate:remote": "wrangler d1 migrations apply demo-mcp --remote",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agenticprimitives/agent-naming": "workspace:*",
    "@agenticprimitives/audit": "workspace:*",
    "@agenticprimitives/delegation": "workspace:*",
    "@agenticprimitives/key-custody": "workspace:*",
    "@agenticprimitives/mcp-runtime": "workspace:*",
    "@agenticprimitives/tool-policy": "workspace:*",
    "@agenticprimitives/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260604.1",
    "@types/node": "^22.7.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
