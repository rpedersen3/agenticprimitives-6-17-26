# demo-sso-next (Vercel) environment — PLACEHOLDERS ONLY (never commit real values).
# Set these in the Vercel project (Settings → Environment Variables); mark the
# *_SECRET / JWK / RPC / KV_* ones as "Sensitive". Local dev: copy to .env.local.

# ── Broker signing key (ES256 / P-256 private JWK, JSON string) ──────────────
# Generate: node ../demo-sso/scripts/gen-broker-key.mjs
BROKER_PRIVATE_JWK={"kty":"EC","crv":"P-256","d":"REPLACE","x":"REPLACE","y":"REPLACE"}
BROKER_KID=broker-1

# ── On-chain resolution (Base Sepolia). Use a keyed RPC in prod (Sensitive). ──
RPC_URL=https://sepolia.base.org

# ── OIDC relying-site allowlist (CN-1) — exact-match redirect URIs, comma-sep ─
REDIRECT_URI_ALLOWLIST=https://agenticprimitives-demo-org.pages.dev/,http://localhost:5473/

# ── Real Google OIDC (optional; see ../demo-sso/OIDC-SETUP.md) ───────────────
GOOGLE_CLIENT_ID=REPLACE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE
# MUST match the redirect URI registered in Google Cloud Console:
GOOGLE_REDIRECT_URI=https://impact-agent.me/oidc/google/callback

# ── demo-a2a relayer backend (stays on Cloudflare) — used by the /a2a rewrite ─
DEMO_A2A_URL=https://demo-a2a-production.richardpedersen3.workers.dev

# ── Vercel KV (Upstash) — auto-injected when you attach a KV store in Vercel. ─
# (Provided by the Vercel KV integration; shown here for local .env.local only.)
KV_REST_API_URL=https://REPLACE.upstash.io
KV_REST_API_TOKEN=REPLACE
