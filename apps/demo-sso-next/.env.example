# demo-sso-next (Vercel) environment — PLACEHOLDERS ONLY (never commit real values).
# Set these in the Vercel project (Settings → Environment Variables); mark the
# *_SECRET / JWK / RPC / KV_* ones as "Sensitive". Local dev: copy to .env.local.

# ── Broker signing key (ES256 / P-256 private JWK, JSON string) ──────────────
# EXT-002: this file MUST NOT contain real key material. The JWK SHAPE was removed
# (pasting a generated key over the placeholder was a known footgun). Generate a
# fresh key + set the env var server-side (Vercel Settings → Environment Variables,
# marked Sensitive) + NEVER commit a populated value.
# Generation script: node ../demo-sso/scripts/gen-broker-key.mjs
BROKER_PRIVATE_JWK=<server-side only — generate with gen-broker-key.mjs, store as Sensitive env>
BROKER_KID=broker-1

# ── On-chain resolution (Base Sepolia). Use a keyed RPC in prod (Sensitive). ──
RPC_URL=https://sepolia.base.org

# ── OIDC relying-site allowlist (CN-1) — exact-match redirect URIs, comma-sep ──
# EXT-017: this env var is no longer the source of truth for the relying-app
# allowlist (SEC-005 derived it from `whitelabel.relyingApps[].redirect_uris` at
# module init). Retained for legacy compatibility but optional in production.
REDIRECT_URI_ALLOWLIST=<optional — preferred source is whitelabel.relyingApps registry>

# ── Issuer Host allowlist (SEC-006) — comma-sep host patterns ────────────────
# Wildcards like `*.impact-agent.me` match exactly ONE label. The broker refuses
# to sign id_tokens with `iss` outside this list. Defaults defined in
# server/_lib/origin.ts (covers impact-agent.me + its subdomains + localhost).
ALLOWED_ISSUER_HOSTS=<optional — defaults in server/_lib/origin.ts>

# ── Custody bridge HMAC secret (SEC-010) — shared with demo-a2a ──────────────
# Required for the Google × KMS resolve call. Server-side only; mark Sensitive.
A2A_CUSTODY_BRIDGE_SECRET=<server-side only — match the value set in demo-a2a>
A2A_CUSTODY_URL=https://<demo-a2a-host>

# ── Real Google OIDC (optional; see ../demo-sso/OIDC-SETUP.md) ───────────────
GOOGLE_CLIENT_ID=REPLACE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE
# MUST match the redirect URI registered in Google Cloud Console:
GOOGLE_REDIRECT_URI=https://impact-agent.me/oidc/google/callback

# ── demo-a2a relayer backend (stays on Cloudflare) — used by the /a2a rewrite ─
DEMO_A2A_URL=https://demo-a2a-production.richardpedersen3.workers.dev

# ── Vercel KV (Upstash) — auto-injected when you attach a KV store in Vercel. ─
# (Provided by the Vercel KV integration; shown here for local .env.local only.)
KV_REST_API_URL=https://REPLACE.upstash.io
KV_REST_API_TOKEN=REPLACE
