{
  "name": "@agenticprimitives-demo/a2a",
  "version": "0.0.2-alpha.2",
  "private": true,
  "description": "Demo a2a-agent: Cloudflare Worker with Durable Object for sessions. SIWE verify, session lifecycle, mints delegation tokens for MCP.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8787 --persist-to ../../.wrangler/state-a2a",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agenticprimitives/agent-account": "workspace:*",
    "@agenticprimitives/agent-naming": "workspace:*",
    "@agenticprimitives/audit": "workspace:*",
    "@agenticprimitives/connect": "workspace:*",
    "@agenticprimitives/delegation": "workspace:*",
    "@agenticprimitives/connect-auth": "workspace:*",
    "@agenticprimitives/key-custody": "workspace:*",
    "@agenticprimitives/mcp-runtime": "workspace:*",
    "@agenticprimitives/types": "workspace:*",
    "hono": "^4.6.0",
    "viem": "^2.50.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/node": "^22.7.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
