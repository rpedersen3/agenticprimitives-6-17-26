auto-install-peers=true
strict-peer-dependencies=false
# R1.7: enable Sigstore provenance on every `pnpm publish` call. The
# changesets/action delegates to pnpm publish, so this setting is what
# turns on --provenance on the underlying call (the CLI flag itself is
# rejected by @changesets/cli's own argv parser). Provenance requires
# OIDC `id-token: write` which release.yml grants, plus either an
# NPM_TOKEN secret or a npm-side trusted-publisher configuration per
# package (the latter is required for first-time publish of new scopes).
provenance=true
